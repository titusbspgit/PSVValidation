1,GPIO,AHB 32-bit register interface,gpio_reg_wr_rd_test,"Purpose: Verify GPIO register reset default values and read/write behavior with masks across GPIO per-pin and group registers as defined in addr_array.",NA,NA,NA,NA,"Skip lists used for VRRW and some group regs; Comment notes DIN bit reads as 1 unless forced, affecting default readback.","Entry point: test_case()
1) Call chk_rst_val()
   1.1) For i=0..CNT-1:
        - addr = addr_array[i]
        - If skip_rst_array[i] == 1: continue
        - If read_mask_array[i] == 0x00000000: continue
        - READ: data_rd = read_reg(addr)
        - COMPUTE: data = (data_rd & 0xFFFFFFFE)
        - CHECK: if (data == default_value_array[i]) else def_fail_cnt++ and printf()
2) Call chk_rd_wr()
   2.1) Initialize chk_val[6] = {0xFFFFFFFF, 0xAAAAAAAA, 0x55555555, 0xF5F5F5F5, 0xA5A5A5A5, 0xFFFF0000}
   2.2) For j=0..5:
        - data_wr = chk_val[j]
        - WRITE phase for i=0..CNT-1:
          • addr = addr_array[i]
          • If skip_array[i] == 1: continue
          • If write_mask_array[i] == 0x00000000: continue
          • WRITE: write_reg(addr, (data_wr & write_mask_array[i]))
        - READ/VERIFY phase for i=0..CNT-1:
          • addr = addr_array[i]
          • If skip_array[i] == 1: continue
          • If write_mask_array[i] == 0x00000000: continue
          • If read_mask_array[i] == 0x00000000: continue
          • READ: data_rd = (read_reg(addr) & read_mask_array[i])
          • COMPUTE: wr_n = (write_mask_array[i] ^ 0xFFFFFFFF)
          • COMPUTE: exp_val = ((data_wr & read_mask_array[i] & write_mask_array[i]) | (wr_n & read_mask_array[i] & default_value_array[i]))
          • CHECK: if (data_rd == exp_val) else wr_fail_cnt++ and printf()
3) Completion:
   - If (def_fail_cnt > 0 || wr_fail_cnt > 0) finish(1) else finish(0)
Timing/waits: none in active paths. Interrupts: none.","MIZAR_GPIO_GP0_GPIO_8,MIZAR_GPIO_GP0_GPIO_9,MIZAR_GPIO_GP0_GPIO_10,MIZAR_GPIO_GP0_GPIO_11,MIZAR_GPIO_GP0_GPIO_12,MIZAR_GPIO_GP0_GPIO_13,MIZAR_GPIO_GP0_GPIO_14,MIZAR_GPIO_GP0_GPIO_15,MIZAR_GPIO_GP0_GPIO_16,MIZAR_GPIO_GP0_GPIO_17,MIZAR_GPIO_GP0_GPIO_18,MIZAR_GPIO_GP0_GPIO_19,MIZAR_GPIO_GP0_GPIO_20,MIZAR_GPIO_GP0_GPIO_21,MIZAR_GPIO_GP0_GPIO_22,MIZAR_GPIO_GP0_GPIO_23,MIZAR_GPIO_GP0_GPIO_24,MIZAR_GPIO_GP0_GPIO_25,MIZAR_GPIO_GP0_GPIO_26,MIZAR_GPIO_GP0_GPIO_27,MIZAR_GPIO_GP0_GPIO_28,MIZAR_GPIO_GP0_GPIO_29,MIZAR_GPIO_GP0_GPIO_30,MIZAR_GPIO_GP0_GPIO_31,MIZAR_GPIO_GP0_GPIO_32,MIZAR_GPIO_GP0_GPIO_33,MIZAR_GPIO_GP0_GPIO_34,MIZAR_GPIO_GP0_GPIO_35,MIZAR_GPIO_GP0_GPIO_36,MIZAR_GPIO_GP0_GPIO_37,MIZAR_GPIO_GP0_GPIO_38,MIZAR_GPIO_GP0_GPIO_39,MIZAR_GPIO_GPIO_INTR_RAW_STCLR1,MIZAR_GPIO_GP0_INTR1_INTR_EN1,MIZAR_GPIO_GP0_INTR1_INTR_STS1,MIZAR_GPIO_GP0_INTR2_INTR_EN1,MIZAR_GPIO_GP0_INTR2_INTR_STS1,MIZAR_GPIO_GPIO_IO_CTRL_GROUP1,MIZAR_GPIO_GPIO_IO_CTRL_GROUP2,MIZAR_GPIO_GPIO_IO_CTRL_GROUP3,MIZAR_GPIO_GPIO_IO_CTRL_GROUP4,MIZAR_GPIO_GPIO_DOUT_GROUP1,MIZAR_GPIO_GPIO_DOUT_GROUP2,MIZAR_GPIO_GPIO_DOUT_GROUP3,MIZAR_GPIO_GPIO_DOUT_GROUP4,MIZAR_GPIO_GPIO_DIN_GROUP1,MIZAR_GPIO_GPIO_DIN_GROUP2,MIZAR_GPIO_GPIO_DIN_GROUP3,MIZAR_GPIO_GPIO_DIN_GROUP4","Default value pass condition: (read_reg(addr) & 0xFFFFFFFE) == default_value_array[i].
Write-read pass condition: (read_reg(addr) & read_mask_array[i]) == ((data_wr & read_mask_array[i] & write_mask_array[i]) | ((write_mask_array[i] ^ 0xFFFFFFFF) & read_mask_array[i] & default_value_array[i])).
Overall PASS: def_fail_cnt == 0 and wr_fail_cnt == 0 leading to finish(0).",
2,GPIO,"interrupts can be generated based on positive edge or negative edge or level high or level low detection at GPIO input.",test_gpio_negedge_intr_en,"Purpose: Validate negative-edge triggered GPIO interrupts for GPIOs 8..39, including per-pin raw/group status, ISR handling, and clears via pin and group RAW_STCLR1 and sysreg routing.",NA,Interrupt,0xA0243ffc,0xA0243ffc,NA,"Entry points: test_case() then Default_IRQHandler() on IRQ.
1) test_case initialization:
   - test_err = 0
   - If GPIO0: GIC_EnableIRQ(87); If GPIO1: GIC_EnableIRQ(88)
   - If GPIO0: WRITE MIZAR_LSS_SYSREG_INTR_EN1 = LSS_SYSREG_INTR_EN1_GPIO0_INTR
     If GPIO1: WRITE MIZAR_LSS_SYSREG_INTR_EN1 = LSS_SYSREG_INTR_EN1_GPIO1_INTR
   - WRITE 0xA0243ffc = 0xFFFFFFFF (drive all high)
2) Configure per-pin negedge and input, clear latched raw:
   For i=0..31:
     - addr1 = MIZAR_GPIO_GP0_GPIO_8 + (i*4)
     - WRITE addr1 = ((1<<20) | (1<<18) | (1<<16))  // doe=1, neie=1, iclr=1
     - wait_on(10)
3) For each pin i generate negedge and wait for ISR with timeout:
   For i=0..31:
     - wr_val = (1u << i)
     - WRITE MIZAR_GPIO_GPIO_INTR_RAW_STCLR1 = wr_val
     - WRITE MIZAR_GPIO_GP0_INTR1_INTR_EN1 = wr_val
     - wait_on(10)
     - int_pend = 1
     - WRITE 0xA0243ffc = 0xFFFFFFFF; wait_on(30)
     - WRITE 0xA0243ffc = ~wr_val  // falling edge on bit i
     - timeout=5000; while(int_pend && timeout--) wait_on(10)
     - If timeout==0: printf("ERROR: Timeout..."), test_err++
4) finish(test_err)
5) Default_IRQHandler():
   - local_wr = (1u << i)
   - int_pend = 0
   - WRITE 0xA0243ffc = 0xFFFFFFFF  // return pads to high
   - raddr = MIZAR_GPIO_GP0_GPIO_8 + (i*4)
   - READ rdata = read_reg(raddr)
   - CHECK DIN after negedge: if ((rdata & 0x1) != 0) test_err++
   - If ((rdata & 0x2) != 0x0):
       • READ rdata_grp = read_reg(MIZAR_GPIO_GP0_INTR1_INTR_STS1)
       • If ((rdata_grp & local_wr) == 0) test_err++
       • WRITE (MIZAR_GPIO_GP0_GPIO_8 + i*4) = ((1<<20)|(1<<16)) // per-pin iclr with doe
       • WRITE MIZAR_GPIO_GPIO_INTR_RAW_STCLR1 = local_wr // group raw clear
       • READ rdata_grp = read_reg(MIZAR_GPIO_GP0_INTR1_INTR_STS1)
         - If (rdata_grp != 0x0) test_err++
       • If GPIO0: WRITE MIZAR_LSS_SYSREG_RAW_STCR1 = LSS_SYSREG_RAW_STCR1_GPIO0_INTR; GIC_ClearIRQ(87)
         If GPIO1: WRITE MIZAR_LSS_SYSREG_RAW_STCR1 = LSS_SYSREG_RAW_STCR1_GPIO1_INTR; GIC_ClearIRQ(88)
     else: test_err++","MIZAR_LSS_SYSREG_INTR_EN1,MIZAR_GPIO_GP0_GPIO_8,MIZAR_GPIO_GPIO_INTR_RAW_STCLR1,MIZAR_GPIO_GP0_INTR1_INTR_EN1,MIZAR_GPIO_GP0_INTR1_INTR_STS1,MIZAR_LSS_SYSREG_RAW_STCR1","Main loop PASS per pin when: ISR occurs before timeout; in ISR, (rdata & 0x1)==0 (DIN low after negedge); (read_reg(MIZAR_GPIO_GP0_INTR1_INTR_STS1) & (1<<i)) != 0 then becomes 0 after clears; sysreg raw status is written to clear; overall test_err remains 0 leading to finish(0).",
3,GPIO,"interrupts can be generated based on positive edge or negative edge or level high or level low detection at GPIO input.",test_gpio_pedge_all_pads_en,"Purpose: Validate positive-edge triggered GPIO interrupts on GPIOs 8..39 with group enable, per-pin raw clear, group masked status clear, and sysreg raw clear.",NA,Interrupt,0xA0243ffc,0xA0243ffc,NA,"Entry points: test_case() then Default_IRQHandler() on IRQ.
1) test_case initialization:
   - If GPIO0: GIC_EnableIRQ(87); If GPIO1: GIC_EnableIRQ(88)
   - If GPIO0: WRITE MIZAR_LSS_SYSREG_INTR_EN1 = LSS_SYSREG_INTR_EN1_GPIO0_INTR
     If GPIO1: WRITE MIZAR_LSS_SYSREG_INTR_EN1 = LSS_SYSREG_INTR_EN1_GPIO1_INTR
2) Configure posedge detection for GPIOs 8..39:
   For i=0..31: WRITE (MIZAR_GPIO_GP0_GPIO_8 + i*4) = 0x00020000 // peie=1
   wait_on(10)
3) Set GPIOs 8..39 as input (doe=1) via group IO control:
   WRITE MIZAR_GPIO_GPIO_IO_CTRL_GROUP1 = 0x000000FF
   WRITE MIZAR_GPIO_GPIO_IO_CTRL_GROUP2 = 0x000000FF
   WRITE MIZAR_GPIO_GPIO_IO_CTRL_GROUP3 = 0x000000FF
   WRITE MIZAR_GPIO_GPIO_IO_CTRL_GROUP4 = 0x000000FF
   wait_on(10)
4) Enable all interrupts in group:
   WRITE MIZAR_GPIO_GP0_INTR1_INTR_EN1 = 0xFFFFFFFF
5) For i=0..31 generate single posedge and wait with timeout:
   - WRITE 0xA0243ffc = 0x00000000; wait_on(10)
   - int_pend = 1
   - WRITE 0xA0243ffc = 0xFFFFFFFF  // rising edge
   - timeout=2000; while (int_pend==1 && --timeout>0) wait_on(10)
   - If timeout==0: printf error, test_err++, break
   - WRITE 0xA0243ffc = 0x00000000; wait_on(10)
6) finish(test_err)
7) Default_IRQHandler():
   - wr_val = (1<<i); int_pend = 0
   - READ rdata_grp = read_reg(MIZAR_GPIO_GP0_INTR1_INTR_STS1)
   - WRITE MIZAR_GPIO_GP0_INTR1_INTR_EN1 = 0x00000000 // mask during service
   - If ((rdata_grp & 0xFFFFFFFF) != 0) OK else error and test_err++
   - For j=0..31: WRITE (MIZAR_GPIO_GP0_GPIO_8 + j*4) = 0x00010000 // iclr per pin
   - wait_on(2)
   - READ rdata_grp = read_reg(MIZAR_GPIO_GP0_INTR1_INTR_STS1); if (rdata_grp == 0x0) OK else error and test_err++
   - If GPIO0: WRITE MIZAR_LSS_SYSREG_RAW_STCR1 = LSS_SYSREG_RAW_STCR1_GPIO0_INTR; READ back and ensure (rdata & bit)==0
     If GPIO1: analogous check for GPIO1
   - WRITE MIZAR_GPIO_GP0_INTR1_INTR_EN1 = 0xFFFFFFFF; GIC_ClearIRQ(87/88 as applicable)","MIZAR_LSS_SYSREG_INTR_EN1,MIZAR_GPIO_GP0_GPIO_8,MIZAR_GPIO_GPIO_IO_CTRL_GROUP1,MIZAR_GPIO_GPIO_IO_CTRL_GROUP2,MIZAR_GPIO_GPIO_IO_CTRL_GROUP3,MIZAR_GPIO_GPIO_IO_CTRL_GROUP4,MIZAR_GPIO_GP0_INTR1_INTR_EN1,MIZAR_GPIO_GP0_INTR1_INTR_STS1,MIZAR_LSS_SYSREG_RAW_STCR1","PASS when for each pin an IRQ is observed before timeout; group masked status (MIZAR_GPIO_GP0_INTR1_INTR_STS1) is non-zero in ISR then becomes 0 after per-pin iclr writes; sysreg RAW_STCR1 written and readback shows respective GPIO raw bit cleared; overall test_err==0 -> finish(0).",
